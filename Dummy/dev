@Library('Tawuniya-lib@main') _

pipeline {
  agent none

  parameters {
    string(name: 'EPIC', defaultValue: '', description: 'Use a Valid Jira Epic Number')
  }

  environment {
    BRANCH_NAME = 'PROD'
    NODE_TLS_REJECT_UNAUTHORIZED = '0'
    GIT_SSL_NO_VERIFY = 'true'
  }

  stages {
    stage('Build + Scan') {
      steps {
        script {
          reactBuildScan(
            epic: params.EPIC,
            branch: env.BRANCH_NAME,
            lob: 'DXP',
            buildAgent: 'built-in',
            secretScanningAgent: 'built-in',
            sonarAgent: 'SonarQube',

            bbs: [
              credentialsId: 'Admin_Bitbucket',
              id: '75b95ed8-28cb-489d-b2fd-a56ac6b6f2ae',
              projectName: 'DXP',
              repositoryName: 'recovery-portal',
              remoteName: 'recovery-portal',
              serverId: '2492752c-5622-4c29-9972-c1c0f572b1f6'
            ],

            app: [
              path: '.',
              packageFile: 'package.json'
            ],

            node: [
  installCmd: '''
    if exist node_modules rmdir /s /q node_modules
    if exist .next rmdir /s /q .next
    npm install --cpu=x64
  ''',

  buildCmd: 'npm run build',

  testCoverageCmd: '''
    if not exist reports mkdir reports
    npx vitest run --coverage --passWithNoTests ^
      --coverage.reporter=lcov ^
      --coverage.reporter=text ^
      --reporter=default ^
      --reporter=junit ^
      --outputFile.junit=reports/junit.xml
  '''
],

            artifacts: [
              path: '.next/**'
            ],

            sonar: [
              projectKey: 'DH-RECOVERY-PORTAL-V3',

              mainGate: 'Quality Gate-Tawuniya',
              prGate: 'Refactor Gate',

              sources: '.',
              tests: '.',

              inclusions: '**/*.ts,**/*.tsx,**/*.js,**/*.jsx',
              testInclusions: '**/*.test.ts,**/*.test.tsx,**/*.spec.ts,**/*.spec.tsx',

              tsconfigPaths: 'tsconfig.json',
              lcovReportPath: 'coverage/lcov.info',

              exclusions: '**/*.map,**/node_modules/**,**/.next/**,**/coverage/**,**/reports/**,**/*.ttf,**/*.otf,**/*.woff,**/*.woff2,**/*.gif,**/*.svg',
              coverageExclusions: '**/*.test.ts,**/*.test.tsx,**/*.spec.ts,**/*.spec.tsx,**/tests/**,**/*.d.ts,**/public/**',
              cpdExclusions: ''
            ]
          )
        }
      }
    }
  }
}