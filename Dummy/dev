@echo off
setlocal EnableDelayedExpansion

REM --- Step 1: Kill stuck processes ---
echo [0/4] Killing stuck processes...
taskkill /F /IM node.exe /T 2>nul
taskkill /F /IM vite.exe /T 2>nul

REM --- Step 2: Configure Environment ---
echo [1/4] Configuring Environment...
set NX_PLUGIN_NO_TIMEOUTS=true
set NX_DAEMON=false
set NX_VERBOSE_LOGGING=true
set CI=true
set NX_TUI=false
set NODE_OPTIONS=--max-old-space-size=8192

REM --- Step 3: Clean ---
echo [2/4] Cleaning...
if exist package-lock.json del /f /q package-lock.json
if exist .nx rmdir /s /q .nx 2>nul
call npm cache clean --force

REM --- Step 4: Install with error check ---
echo [3/4] Installing...
call npm install --legacy-peer-deps
if %ERRORLEVEL% NEQ 0 (
    echo [ERROR] npm install failed with code %ERRORLEVEL%. Aborting build.
    exit /b %ERRORLEVEL%
)

REM --- Step 5: Build with error check ---
echo [4/4] Building...
call npx nx reset
if %ERRORLEVEL% NEQ 0 (
    echo [ERROR] nx reset failed with code %ERRORLEVEL%. Aborting build.
    exit /b %ERRORLEVEL%
)

echo ^> Starting Build with NO TIMEOUTS...
call npx nx build aamal --configuration=prod --verbose
if %ERRORLEVEL% NEQ 0 (
    echo [ERROR] nx build failed with code %ERRORLEVEL%.
    exit /b %ERRORLEVEL%
)

echo ^> Build completed successfully.
endlocal