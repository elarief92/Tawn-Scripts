        stage('Detect Changed Packages') {
    steps {
        script {
            def diffOutput = bat(
                returnStdout: true,
                script: """
@echo off
git diff-tree --no-commit-id --name-only -r HEAD
"""
            ).trim()

            echo "Changed files raw output:\n${diffOutput}"

            def changedFiles = diffOutput ? diffOutput.readLines() : []

            def packageSet = [] as Set

            changedFiles.each { file ->
                def normalized = file.replace('\\', '/')
                def matcher = normalized =~ /(?i)^Packages\\/([^\\/]+)\\//

                if (matcher.find()) {
                    packageSet << matcher.group(1)
                }
            }

            CHANGED_PACKAGES = packageSet.toList().sort()

            echo "Detected packages: ${CHANGED_PACKAGES.join(', ')}"

            if (CHANGED_PACKAGES.isEmpty()) {
                error("No package changes detected under Packages/. Job failed.")
            }
        }
    }
}

       
