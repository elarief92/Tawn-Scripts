                script: [
                    classpath: [],
                    sandbox: true,
                    script: '''
                        if (ENVIRONMENT == 'DEV') {
                            return ['DEV_APP01', 'DEV_APP02']
                        } else if (ENVIRONMENT == 'QC') {
