        stage('Sync Dev') {
            steps {
               script {
                   echo "DEV"
                    withCredentials([usernamePassword(credentialsId: 'Admin_Bitbucket', usernameVariable: 'USERNAME', passwordVariable: 'PASSWORD')]) {
                    
                    def encodedPassword = URLEncoder.encode("$PASSWORD",'UTF-8')
                    
                    sh """
                        git version
                        git config --global user.email "${USERNAME}"
                        git config --global user.name "${USERNAME}"
                        git config --list
                        
                        git clone https://${USERNAME}:${encodedPassword}@${GitHost}
                        pwd
                        cd /home/apiadmin/jenkins/workspace/API/Sync_Develop/eidevopsassests/
                        git checkout develop
                        git pull https://${USERNAME}:${encodedPassword}@${GitHost} develop
                        git branch -a
                        git merge master
                        git push https://${USERNAME}:${encodedPassword}@${GitHost} develop
                        
                    """
                }
                }
            }
