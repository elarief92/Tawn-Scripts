properties([
    parameters([
        string(
            name: 'EPIC_NAME',
            defaultValue: '',
            description: 'Same EPIC used in deployment job'
        ),

        booleanParam(
            name: 'CONFIRM_ROLLBACK',
            defaultValue: false,
            description: 'Must be checked before rollback execution'
        ),

        booleanParam(
            name: 'DELETE_PROJECT_AFTER_ROLLBACK',
            defaultValue: true,
            description: 'Delete Deployer candidate/project after successful rollback'
        )
    ])
])

pipeline {
    agent { label 'SAG-PREP-IPP02' }

    options {
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '5'))
        timestamps()
    }

    environment {
        SAG_HOME = '/sag/be1015'

        DEPLOYER_BIN = "${SAG_HOME}/IntegrationServer/instances/default/packages/WmDeployer/bin"
        DEPLOYER_CMD = "${DEPLOYER_BIN}/Deployer.sh"

        DEPLOYER_HOST = '127.0.0.1'
        DEPLOYER_PORT = '5555'

        EMAIL_RECIPIENTS = 'melarief@tawuniya.com'
        EMAIL_SUBJECT = 'API Rollback'
        APPLICATION_NAME = 'webMethods API'
    }

    stages {

        stage('Validate Input') {
            steps {
                script {

                    if (!params.EPIC_NAME?.trim()) {
                        error("EPIC_NAME is required")
                    }

                    if (!params.CONFIRM_ROLLBACK) {
                        error("CONFIRM_ROLLBACK must be checked before running rollback")
                    }

                    if (!fileExists(env.DEPLOYER_CMD)) {
                        error("Deployer command not found: ${env.DEPLOYER_CMD}")
                    }

                    currentBuild.displayName = "ROLLBACK-${params.EPIC_NAME}"
                    currentBuild.description = "Rollback EPIC=${params.EPIC_NAME}"

                    echo "Rollback Project: ${params.EPIC_NAME}"
                    echo "Rollback Candidate: ${params.EPIC_NAME}"
                    echo "Delete project after rollback: ${params.DELETE_PROJECT_AFTER_ROLLBACK}"
                }
            }
        }

        stage('Approval Before Rollback') {
            steps {
                script {

                    def approval = input(
                        message: "Confirm rollback for EPIC ${params.EPIC_NAME} ?",
                        ok: "Rollback Now",
                        parameters: [
                            string(
                                name: 'APPROVER_COMMENT',
                                defaultValue: '',
                                description: 'Reason / approval comment'
                            )
                        ]
                    )

                    env.APPROVER_COMMENT = approval
                }
            }
        }

        stage('Send Rollback Start Email') {
            steps {
                script {

                    sendRollbackEmail(
                        'Started',
                        '#2b2626',
                        "Rollback has been started for ${env.APPLICATION_NAME}."
                    )
                }
            }
        }

        stage('Execute Rollback') {
            steps {

                withCredentials([
                    usernamePassword(
                        credentialsId: 'IS_Target_Preprod',
                        usernameVariable: 'DEPLOYER_USER',
                        passwordVariable: 'DEPLOYER_PWD'
                    )
                ]) {

                    sh '''
                        chmod +x "${DEPLOYER_CMD}" || true

                        echo "Executing rollback..."
                        echo "Project: ${EPIC_NAME}"
                        echo "Candidate: ${EPIC_NAME}"

                        "${DEPLOYER_CMD}" --rollback \
                            -project "${EPIC_NAME}" \
                            -dc "${EPIC_NAME}" \
                            -host "${DEPLOYER_HOST}" \
                            -port "${DEPLOYER_PORT}" \
                            -user "${DEPLOYER_USER}" \
                            -pwd "${DEPLOYER_PWD}"

                        echo "Rollback completed successfully."
                    '''
                }
            }
        }

        stage('Delete Deployment Candidate') {

            when {
                expression { return params.DELETE_PROJECT_AFTER_ROLLBACK }
            }

            steps {

                withCredentials([
                    usernamePassword(
                        credentialsId: 'IS_Target_Preprod',
                        usernameVariable: 'DEPLOYER_USER',
                        passwordVariable: 'DEPLOYER_PWD'
                    )
                ]) {

                    sh '''
                        echo "Deleting deployment candidate/resources..."
                        echo "Project: ${EPIC_NAME}"
                        echo "Candidate: ${EPIC_NAME}"

                        "${DEPLOYER_CMD}" --delete \
                            -project "${EPIC_NAME}" \
                            -dc "${EPIC_NAME}" \
                            -host "${DEPLOYER_HOST}" \
                            -port "${DEPLOYER_PORT}" \
                            -user "${DEPLOYER_USER}" \
                            -pwd "${DEPLOYER_PWD}" || true

                        echo "Deployment candidate cleanup completed."
                    '''
                }
            }
        }

        stage('Delete Deployer Project') {

            when {
                expression { return params.DELETE_PROJECT_AFTER_ROLLBACK }
            }

            steps {

                withCredentials([
                    usernamePassword(
                        credentialsId: 'IS_Target_Preprod',
                        usernameVariable: 'DEPLOYER_USER',
                        passwordVariable: 'DEPLOYER_PWD'
                    )
                ]) {

                    sh '''
                        echo "Deleting Deployer project..."
                        echo "Project: ${EPIC_NAME}"

                        "${DEPLOYER_CMD}" --delete \
                            -project "${EPIC_NAME}" \
                            -host "${DEPLOYER_HOST}" \
                            -port "${DEPLOYER_PORT}" \
                            -user "${DEPLOYER_USER}" \
                            -pwd "${DEPLOYER_PWD}" || true

                        echo "Deployer project cleanup completed."
                    '''
                }
            }
        }
    }

    post {

        success {

            script {

                sendRollbackEmail(
                    'Success',
                    '#2b2626',
                    "Rollback has been completed successfully for ${env.APPLICATION_NAME}."
                )
            }
        }

        failure {

            script {

                sendRollbackEmail(
                    'Failed',
                    '#2b2626',
                    "Rollback has failed for ${env.APPLICATION_NAME}."
                )
            }
        }

        always {
            echo "Rollback job finished."
        }
    }
}

def sendRollbackEmail(status, color, message) {

    emailext(
        to: "${env.EMAIL_RECIPIENTS}",
        subject: "${env.EMAIL_SUBJECT} ${params.EPIC_NAME} - ${status}",
        mimeType: 'text/html',
        recipientProviders: [[$class: 'DevelopersRecipientProvider']],
        body: """\
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<style>
body{font-family:Arial,sans-serif;background:#f4f4f4;color:#333}
.container{width:600px;margin:20px auto;background:#fff;border-radius:8px;overflow:hidden;box-shadow:0 2px 5px rgba(0,0,0,.1)}
.header{background:${color};color:#fff;padding:18px;text-align:center;font-size:22px;font-weight:bold}
.content{padding:20px}
.details{background:#ecf0f1;padding:15px;border-radius:6px;margin:20px 0}
.details p{margin:6px 0}
.footer{font-size:14px;color:#7f8c8d;text-align:center;padding:15px}
</style>
</head>

<body>

<div class="container">

<div class="header">
TAWUNIYA - Rollback ${status}
</div>

<div class="content">

<p>Dears,</p>

<p>${message}</p>

<div class="details">

<p><strong>Application:</strong> ${env.APPLICATION_NAME}</p>

<p><strong>EPIC / Project:</strong> ${params.EPIC_NAME}</p>

<p><strong>Deployment Candidate:</strong> ${params.EPIC_NAME}</p>

<p><strong>Delete Project After Rollback:</strong> ${params.DELETE_PROJECT_AFTER_ROLLBACK}</p>

<p><strong>Approval Comment:</strong> ${env.APPROVER_COMMENT ?: 'N/A'}</p>

<p><strong>Status:</strong> ${status}</p>

<p><strong>Rollback Date-Time:</strong> ${new Date().format('yyyy-MM-dd HH:mm:ss')}</p>

<p><strong>Build URL:</strong>
<a href="${env.BUILD_URL}">${env.BUILD_URL}</a>
</p>

</div>

<p>Please be advised accordingly.</p>

</div>

<div class="footer">

<p>Thank you for your cooperation.</p>

<p>
<strong>Best regards,</strong><br>
The DevOps Team
</p>

</div>

</div>

</body>
</html>
"""
    )
}