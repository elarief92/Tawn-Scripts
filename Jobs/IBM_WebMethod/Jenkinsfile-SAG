properties([
    parameters([

        string(
            name: 'EPIC_NAME',
            defaultValue: '',
            description: 'Required. e.g. EPIC-1234'
        ),

        [
            $class: 'ChoiceParameter',
            choiceType: 'PT_SINGLE_SELECT',
            name: 'ENVIRONMENT',
            description: 'Select environment',
            script: [
                $class: 'GroovyScript',
                fallbackScript: [
                    classpath: [],
                    sandbox: true,
                    script: 'return ["DEV"]'
                ],
                script: [
                    classpath: [],
                    sandbox: true,
                    script: '''
                        return ["DEV", "QC", "PROD"]
                    '''
                ]
            ]
        ],

        [
            $class: 'CascadeChoiceParameter',
            choiceType: 'PT_CHECKBOX',
            name: 'TARGET_SCOPE',
            description: 'Select target servers',
            referencedParameters: 'ENVIRONMENT',
            script: [
                $class: 'GroovyScript',
                fallbackScript: [
                    classpath: [],
                    sandbox: true,
                    script: 'return ["QC_APP01"]'
                ],
                script: [
                    classpath: [],
                    sandbox: true,
                    script: '''
                        if (ENVIRONMENT == 'DEV') {
                            return ['QC_APP01', 'QC_APP04']
                        } else if (ENVIRONMENT == 'QC') {
                            return ['QC_APP02', 'QC_APP05']
                        } else if (ENVIRONMENT == 'PROD') {
                            return ['QC_APP03', 'QC_APP06']
                        } else {
                            return ['None']
                        }
                    '''
                ]
            ]
        ],

        [
            $class: 'ChoiceParameter',
            choiceType: 'PT_CHECKBOX',
            name: 'PACKAGES_TO_BUILD',
            description: 'Select packages',
            script: [
                $class: 'GroovyScript',
                fallbackScript: [
                    classpath: [],
                    sandbox: true,
                    script: 'return ["TawnMotorNonRetail"]'
                ],
                script: [
                    classpath: [],
                    sandbox: true,
                    script: '''
                        return [
                            "TawnMotorNonRetail",
                            "TawnSMESalesCRM"
                        ]
                    '''
                ]
            ]
        ]
    ])
])

pipeline {
    agent { label 'built-in' }

    options {
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '20'))
    }

    environment {
        DEPLOYER_HOST = 'localhost'
        DEPLOYER_PORT = '5555'

        TEMP_SRC      = "${WORKSPACE}\\.tmp_build_src"
        GENERATED_DIR = "${WORKSPACE}\\generated"
        GENERATED_XML = "${WORKSPACE}\\generated\\Deployment_ProjectAutomator.xml"

        TEMPLATE_XML  = 'deployer/templates/ProjectAutomator.Repository.template.xml'
    }

    stages {

        stage('Validate') {
            steps {
                script {
                    if (!params.EPIC_NAME?.trim()) {
                        error("EPIC_NAME required")
                    }

                    if (!params.ENVIRONMENT?.trim()) {
                        error("ENVIRONMENT required")
                    }

                    def selectedTargets  = getSelected(params.TARGET_SCOPE)
                    def selectedPackages = getSelected(params.PACKAGES_TO_BUILD)

                    if (selectedTargets.isEmpty()) {
                        error("Select at least 1 target")
                    }

                    if (selectedPackages.isEmpty()) {
                        error("Select at least 1 package")
                    }

                    echo "ENV      : ${params.ENVIRONMENT}"
                    echo "EPIC     : ${params.EPIC_NAME}"
                    echo "Targets  : ${selectedTargets.join(', ')}"
                    echo "Packages : ${selectedPackages.join(', ')}"
                }
            }
        }

        stage('Checkout Repo') {
            steps {
                script {
                    def branchName = getEnvironmentConfig(params.ENVIRONMENT).branch

                    deleteDir()

                    bbs_checkout(
                        branches: [[name: "*/${branchName}"]],
                        credentialsId: 'Admin_Bitbucket',
                        id: '75b95ed8-28cb-489d-b2fd-a56ac6b6f2ae',
                        projectName: 'JIRA',
                        repositoryName: 'sag',
                        serverId: '2492752c-5622-4c29-9972-c1c0f572b1f6'
                    )
                }
            }
        }

        stage('Validate Files') {
            steps {
                script {
                    if (!fileExists(env.TEMPLATE_XML)) {
                        error("Template XML not found in workspace: ${env.TEMPLATE_XML}")
                    }

                    def packages = getSelected(params.PACKAGES_TO_BUILD)
                    for (pkg in packages) {
                        if (!fileExists("packages/${pkg}")) {
                            error("Package not found: packages/${pkg}")
                        }
                    }
                }
            }
        }

        stage('Prepare Temp Source') {
            steps {
                bat """
                    @echo off
                    if exist "${env.TEMP_SRC}" rmdir /s /q "${env.TEMP_SRC}"
                    if exist "${env.GENERATED_DIR}" rmdir /s /q "${env.GENERATED_DIR}"

                    mkdir "${env.TEMP_SRC}"
                    mkdir "${env.GENERATED_DIR}"
                    mkdir "${env.TEMP_SRC}\\packages"
                """

                script {
                    def packages = getSelected(params.PACKAGES_TO_BUILD)

                    for (pkg in packages) {
                        bat """
                            @echo off
                            if not exist "${WORKSPACE}\\packages\\${pkg}" (
                                echo Package not found: ${WORKSPACE}\\packages\\${pkg}
                                exit /b 1
                            )

                            if not exist "${env.TEMP_SRC}\\packages\\${pkg}" mkdir "${env.TEMP_SRC}\\packages\\${pkg}"

                            xcopy "${WORKSPACE}\\packages\\${pkg}\\*" "${env.TEMP_SRC}\\packages\\${pkg}\\" /E /I /Y >nul
                            if errorlevel 1 exit /b 1
                        """
                    }
                }
            }
        }

        stage('Generate XML') {
            steps {
                script {
                    def targets  = getTargetConfigs(params.ENVIRONMENT, params.TARGET_SCOPE)
                    def packages = getSelected(params.PACKAGES_TO_BUILD)
                    def names    = buildNames(params.EPIC_NAME, params.ENVIRONMENT, targets)

                    def xml = readFile(file: env.TEMPLATE_XML, encoding: 'UTF-8')

                    xml = xml.replace('@DEPLOYER_HOST@', env.DEPLOYER_HOST)
                    xml = xml.replace('@DEPLOYER_PORT@', env.DEPLOYER_PORT)
                    xml = xml.replace('@DEPLOYER_USER@', '${Username}')
                    xml = xml.replace('@DEPLOYER_PWD@', '${Password}')

                    xml = xml.replace('@IS_ALIASES@', buildISAliases(targets))
                    xml = xml.replace('@TARGET_ALIASES@', buildTargetAliases(targets))
                    xml = xml.replace('@DEPLOYMENT_ENTRIES@', buildEntries(packages))

                    xml = xml.replace('@PROJECT_NAME@', names)
                    xml = xml.replace('@PROJECT_DESC@', names)
                    xml = xml.replace('@DEPLOYMENT_SET_NAME@', names + "_SET")
                    xml = xml.replace('@MAP_NAME@', names + "_MAP")
                    xml = xml.replace('@CANDIDATE_NAME@', names)
                    xml = xml.replace('@REPO_ALIAS@', 'RepoSource')
                    xml = xml.replace('@REPO_DIRECTORY@', env.TEMP_SRC.replace('\\', '\\\\'))

                    writeFile(file: env.GENERATED_XML, text: xml, encoding: 'UTF-8')

                    echo '===== Generated XML ====='
                    echo readFile(file: env.GENERATED_XML, encoding: 'UTF-8')
                }
            }
        }

        stage('Archive XML') {
            steps {
                archiveArtifacts artifacts: 'generated/*.xml', allowEmptyArchive: false
            }
        }
    }
}

def getSelected(val) {
    if (!val?.trim()) {
        return []
    }

    return val.split(',')
              .collect { it.trim() }
              .findAll { it && it != 'None' }
}

def buildNames(epic, envName, targets) {
    return "${epic}_${envName}_${targets.collect { it.alias }.join('_')}"
}

def buildEntries(pkgs) {
    return pkgs.collect {
        """                <Component componentType="*" compositeName="${it}" name="*" srcAlias="RepoSource" type="IS"/>"""
    }.join('\n')
}

def buildISAliases(targets) {
    return targets.collect {
        """            <isalias name="${it.alias}">
                <host>${it.host}</host>
                <port>${it.port}</port>
                <user>Administrator</user>
                <pwd>\${Password}</pwd>
                <useSSL>false</useSSL>
                <installDeployerResource>false</installDeployerResource>
                <Test>false</Test>
            </isalias>"""
    }.join('\n')
}

def buildTargetAliases(targets) {
    return targets.collect {
        """                <alias type="IS">${it.alias}</alias>"""
    }.join('\n')
}

def getEnvironmentConfig(envName) {
    def config = [
        DEV : [branch: 'DEV'],
        QC  : [branch: 'QC'],
        PROD: [branch: 'PROD']
    ]

    if (!config.containsKey(envName)) {
        error("Unsupported ENVIRONMENT: ${envName}")
    }

    return config[envName]
}

def getTargetConfigs(envName, scopeCsv) {
    def map = [
        'QC_APP01':[alias:'QC_APP01', host:'10.24.7.181', port:'5555'],
        'QC_APP02':[alias:'QC_APP02', host:'10.24.7.182', port:'5555'],
        'QC_APP03':[alias:'QC_APP03', host:'10.24.7.183', port:'5555'],
        'QC_APP04':[alias:'QC_APP04', host:'10.24.7.184', port:'5555'],
        'QC_APP05':[alias:'QC_APP05', host:'10.24.7.185', port:'5555'],
        'QC_APP06':[alias:'QC_APP06', host:'10.24.7.186', port:'5555']
    ]

    def allowed = [
        DEV : ['QC_APP01', 'QC_APP04'],
        QC  : ['QC_APP02', 'QC_APP05'],
        PROD: ['QC_APP03', 'QC_APP06']
    ]

    def selected = getSelected(scopeCsv)

    selected.each {
        if (!allowed[envName].contains(it)) {
            error("${it} not allowed for ${envName}")
        }
    }

    return selected.collect { map[it] }
}