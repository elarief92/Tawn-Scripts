        to: "${env.EMAIL_RECIPIENTS}",
        subject: "${env.EMAIL_SUBJECT} ${params.EPIC_NAME} - ${status}",
        mimeType: 'text/html',
        recipientProviders: [[$class: 'DevelopersRecipientProvider']],
        body: """\
            <!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><style>
            body{font-family:Arial,sans-serif;background:#f4f4f4;color:#333}
            .container{width:600px;margin:20px auto;background:#fff;border-radius:8px;overflow:hidden;box-shadow:0 2px 5px rgba(0,0,0,.1)}
            .header{background:${color};color:#fff;padding:18px;text-align:center;font-size:22px;font-weight:bold}
            .content{padding:20px}.details{background:#ecf0f1;padding:15px;border-radius:6px;margin:20px 0}.details p{margin:6px 0}
            .footer{font-size:14px;color:#7f8c8d;text-align:center;padding:15px}
            </style></head><body><div class="container"><div class="header">TAWUNIYA - Deployment ${status}</div>
            <div class="content"><p>Dears,</p><p>${message}</p><div class="details">
            <p><strong>Application:</strong> ${env.APPLICATION_NAME}</p>
            <p><strong>Environment:</strong> ${params.ENVIRONMENT}</p>
            <p><strong>EPIC:</strong> <a href="https://bitbucket.tawn.com/plugins/servlet/jira-integration/issues/${params.EPIC_NAME}">${params.EPIC_NAME}</a></p>
            <p><strong>Packages:</strong> ${getSelected(params.PACKAGES_TO_BUILD).join(', ')}</p>
            <p><strong>Status:</strong> ${status}</p>
            <p><strong>Deployment Date-Time:</strong> ${new Date().format('yyyy-MM-dd HH:mm:ss')}</p>
            <p><strong>Build URL:</strong> <a href="${env.BUILD_URL}">${env.BUILD_URL}</a></p>
            </div><p>Please be advised accordingly.</p></div>
            <div class="footer"><p>Thank you for your cooperation.</p><p><strong>Best regards,</strong><br>The DevOps Team</p></div>
            </div></body></html>
        """
    )
}

def getSelected(val) {
    val?.trim() ? val.split(',').collect { it.trim() }.findAll { it && it != 'None' } : []
}

def buildNames(epic, environmentName) {
    def e = epic.trim()
    [
        PROJECT_NAME: e,
        PROJECT_DESC: "Project created for EPIC ${e} on ${environmentName} environment",
        DEPLOYMENT_SET_NAME: "${e}_DEPLOYMENT_SET",
        DEPLOYMENT_MAP_NAME: "${e}_DEPLOYMENT_MAP",
        CANDIDATE_NAME: e
    ]
}

def buildRepositoryEntries(pkgs, repoAlias) {
    pkgs.collect { """<Composite name="${it}" srcAlias="${repoAlias}" type="IS"/>""" }.join('\n')
}

def buildISAliases(targets) {
    targets.collect { t -> """            <isalias name="${t.alias}">
                <host>${t.host}</host>
                <port>${t.port}</port>
                <user>\${IS_USER}</user>
                <pwd>\${IS_PWD}</pwd>
                <useSSL>false</useSSL>
                <installDeployerResource>false</installDeployerResource>
                <Test>false</Test>
            </isalias>""" }.join('\n')
}

def buildMapTargetAliases(targets) {
    targets.collect { """<alias type="IS">${it.alias}</alias>""" }.join('\n')
}

def getEnvironmentConfig(envName) {
    def config = [
        DEV : [branch: 'DEV_CICD'],
        QC  : [branch: 'QC'],
        PROD: [branch: 'PROD']
    ]

    if (!config[envName]) {
        error("Unsupported ENVIRONMENT: ${envName}")
    }

    config[envName]
}

def getTargetConfigs(envName, scopeCsv) {
    def targetConfigMap = [
        'PREPROD_APP01': [alias: 'PREPROD_APP01', host: '10.7.248.74',  port: '5555'],
        'DEV_APP02'    : [alias: 'DEV_APP02',     host: '10.24.7.172', port: '5555'],
        'QC_APP01'     : [alias: 'QC_APP01',      host: '10.24.7.181', port: '5555'],
        'QC_APP04'     : [alias: 'QC_APP04',      host: '10.24.7.184', port: '5555'],
        'PRD_APP01'    : [alias: 'PRD_APP01',     host: '10.24.7.191', port: '5555'],
        'PRD_APP02'    : [alias: 'PRD_APP02',     host: '10.24.7.192', port: '5555']
    ]

    def allowedTargetsByEnvironment = [
        DEV : ['PREPROD_APP01', 'DEV_APP02'],
        QC  : ['QC_APP01', 'QC_APP04'],
        PROD: ['PRD_APP01', 'PRD_APP02']
    ]

    def selectedTargets = getSelected(scopeCsv)

    selectedTargets.each { t ->
        if (!allowedTargetsByEnvironment[envName]?.contains(t)) {
            error("${t} is not allowed for environment ${envName}")
        }

        if (!targetConfigMap[t]) {
            error("No target configuration found for ${t}")
        }
    }

    selectedTargets.collect { targetConfigMap[it] }
}