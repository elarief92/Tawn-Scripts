properties([
    parameters([
        string(name: 'EPIC_NAME', defaultValue: '', description: 'Use a Valid Jira Epic Number'),

        [
            $class: 'ChoiceParameter',
            choiceType: 'PT_SINGLE_SELECT',
            name: 'ENVIRONMENT',
            description: 'Select environment',
            script: [
                $class: 'GroovyScript',
                fallbackScript: [classpath: [], sandbox: true, script: 'return ["DEV"]'],
                script: [classpath: [], sandbox: true, script: 'return ["DEV", "QC", "PROD"]']
            ]
        ],

        [
            $class: 'CascadeChoiceParameter',
            choiceType: 'PT_CHECKBOX',
            name: 'TARGET_SCOPE',
            description: 'Select target servers',
            referencedParameters: 'ENVIRONMENT',
            filterable: true,
            filterLength: 2,
            script: [
                $class: 'GroovyScript',
                fallbackScript: [classpath: [], sandbox: true, script: 'return ["PREPROD_APP01"]'],
                script: [classpath: [], sandbox: true, script: '''
                    if (ENVIRONMENT == "DEV") {
                        return ["PREPROD_APP01", "DEV_APP02"]
                    }
                    else if (ENVIRONMENT == "QC") {
                        return ["QC_APP01", "QC_APP04"]
                    }
                    else if (ENVIRONMENT == "PROD") {
                        return ["PRD_APP01", "PRD_APP02"]
                    }
                    else {
                        return ["None"]
                    }
                ''']
            ]
        ],

        [
            $class: 'ChoiceParameter',
            choiceType: 'PT_CHECKBOX',
            name: 'PACKAGES_TO_BUILD',
            description: 'Select packages to build and deploy',
            filterable: true,
            filterLength: 2,
            script: [
                $class: 'GroovyScript',
                fallbackScript: [classpath: [], sandbox: true, script: 'return ["PSUtilities"]'],
                script: [
                    classpath: [],
                    sandbox: true,
                    script: '''
                        return [
                            "PSUtilities",
                            "TawncheckoutPayment",
                            "TawnMedDomesticWorker",
                            "TawnMobileApplication",
                            "TawnMotorNonRetail",
                            "TawnSMEMedicalProcess",
                            "TawnSMESalesCRM",
                            "zzCharan",
                            "zzConnectivityCheck",
                            "zzHanu",
                            "zzwebmpoc"
                        ]
                    '''
                ]
            ]
        ]
    ])
])

def CHANGED_PACKAGES = []
def DEPLOY_STATUS = "SUCCESS"

pipeline {
    agent { label 'SAG-PREP-IPP02' }

    options {
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '3'))
        timestamps()
    }

    environment {
        SAG_HOME = '/sag/be1015'
        JAVA_HOME = '/sag/be1015/jvm/jvm'

        ABE_BUILD_FILE = "${SAG_HOME}/common/AssetBuildEnvironment/master_build/build.xml"
        DEPLOYER_BIN = "${SAG_HOME}/IntegrationServer/instances/default/packages/WmDeployer/bin"
        PROJECT_AUTOMATOR = "${DEPLOYER_BIN}/projectautomatorUnix.sh"
        DEPLOYER_CMD = "${DEPLOYER_BIN}/Deployer.sh"

        TEMP_SRC = "${WORKSPACE}/.tmp_build_src"
        BUILD_OUTPUT_DIR = "${WORKSPACE}/build_output"
        GENERATED_DIR = "${WORKSPACE}/generated"
        GENERATED_XML = "${WORKSPACE}/generated/Deployment_ProjectAutomator.xml"
        BUILD_LOG_FILE = "${WORKSPACE}/generated/abe-build.log"

        TEMPLATE_XML = '01-deployer/templates/ProjectAutomator.Repository.template.xml'

        DEPLOYER_HOST = '127.0.0.1'
        DEPLOYER_PORT = '5555'
        REPO_ALIAS = 'BuildRepo'

        EMAIL_RECIPIENTS = 'melarief@tawuniya.com'
        EMAIL_SUBJECT = 'API Deployment'
        APPLICATION_NAME = 'webMethods API'
    }

    stages {
        stage('Validate Input') {
            steps {
                script {
                    if (!params.EPIC_NAME?.trim()) error("EPIC_NAME is required")
                    if (!params.ENVIRONMENT?.trim()) error("ENVIRONMENT is required")
                    if (getSelected(params.TARGET_SCOPE).isEmpty()) error("Select at least one target server")

                    CHANGED_PACKAGES = getSelected(params.PACKAGES_TO_BUILD)

                    if (CHANGED_PACKAGES.isEmpty()) error("Select at least one package")

                    echo "Selected packages: ${CHANGED_PACKAGES.join(', ')}"
                    echo "Selected targets: ${getSelected(params.TARGET_SCOPE).join(', ')}"
                }
            }
        }

        stage('Set Build Name') {
            steps {
                script {
                    currentBuild.displayName = "${params.EPIC_NAME}"
                    currentBuild.description = "EPIC=${params.EPIC_NAME} | ENV=${params.ENVIRONMENT}"
                }
            }
        }

        stage('Send Start Email') {
            steps {
                script {
                    sendDeploymentEmail(
                        'Started',
                        '#f39c12',
                        "We are pleased to inform you that the deployment of ${env.APPLICATION_NAME} has been started as follows:"
                    )
                }
            }
        }

        stage('Checkout Repo') {
            steps {
                script {
                    def branchName = getEnvironmentConfig(params.ENVIRONMENT).branch

                    echo "Environment selected: ${params.ENVIRONMENT}"
                    echo "Branch selected for checkout: ${branchName}"

                    deleteDir()

                   bbs_checkout(
                        branches: [[name: "*/${branchName}"]],
                        credentialsId: 'Admin_Bitbucket',
                        id: '06c55797-80ad-4cb9-bea7-299d2a91506e',
                        projectName: 'EI',
                        repositoryName: 'webmethods-source-code',
                        serverId: '2492752c-5622-4c29-9972-c1c0f572b1f6',
                    
                        cloneOptions: [
                            shallow: true,
                            depth: 1
                        ]
                    )
                }
            }
        }

        stage('Validate Repo Content') {
            steps {
                script {
                    if (!fileExists(env.TEMPLATE_XML)) {
                        error("Template XML not found after checkout: ${env.TEMPLATE_XML}")
                    }

                    for (pkg in CHANGED_PACKAGES) {
                        if (!fileExists("IS/${pkg}")) {
                            error("Package not found in repo: IS/${pkg}")
                        }
                    }
                }
            }
        }

        stage('Prepare Build Source') {
            steps {
                sh '''
                    rm -rf "${TEMP_SRC}" "${BUILD_OUTPUT_DIR}" "${GENERATED_DIR}"
                    mkdir -p "${TEMP_SRC}" "${BUILD_OUTPUT_DIR}" "${GENERATED_DIR}"
                '''

                script {
                    for (pkg in CHANGED_PACKAGES) {
                        sh """
                            if [ ! -d "${env.WORKSPACE}/IS/${pkg}" ]; then
                                echo "Missing package: ${pkg}"
                                exit 1
                            fi

                            mkdir -p "${env.TEMP_SRC}/${pkg}"
                            cp -R "${env.WORKSPACE}/IS/${pkg}/." "${env.TEMP_SRC}/${pkg}/"
                        """
                    }
                }
            }
        }

        stage('ABE Build') {
            steps {
                sh '''
                    set -o pipefail

                    export PATH=$JAVA_HOME/bin:$PATH
                    unset CLASSPATH

                    export ANT_OPTS="-Xms2g -Xmx16g -XX:+UseG1GC"
                    export JAVA_OPTS="-Xms2g -Xmx16g -XX:+UseG1GC"
                    export _JAVA_OPTIONS="-Xms2g -Xmx16g -XX:+UseG1GC"

                    cd "${SAG_HOME}/common/AssetBuildEnvironment/master_build"

                    ANT_ARGS="-Dbuild.output.dir=${BUILD_OUTPUT_DIR} -Dbuild.source.dir=${TEMP_SRC} -Denable.checkout=false -Denable.archive=false -Denable.build.IS=true" "${SAG_HOME}/common/AssetBuildEnvironment/bin/build.sh" 2>&1 | tee "${BUILD_LOG_FILE}"
                '''
            }
        }

        stage('Validate ABE Output') {
            steps {
                sh '''
                    echo "Checking ABE output..."
                    find "${BUILD_OUTPUT_DIR}" -maxdepth 3 -type f | sort

                    if [ ! -d "${BUILD_OUTPUT_DIR}/IS" ]; then
                        echo "ERROR: ${BUILD_OUTPUT_DIR}/IS not found"
                        exit 1
                    fi

                    if ! ls "${BUILD_OUTPUT_DIR}/IS"/*.acdl >/dev/null 2>&1; then
                        echo "ERROR: No ACDL files generated"
                        exit 1
                    fi
                '''
            }
        }

        stage('Generate Project Automator XML') {
            steps {
                script {
                    def targets = getTargetConfigs(params.ENVIRONMENT, params.TARGET_SCOPE)
                    def names = buildNames(params.EPIC_NAME, params.ENVIRONMENT)
                    def xml = readFile(file: env.TEMPLATE_XML, encoding: 'UTF-8')

                    xml = xml.replace('@DEPLOYER_HOST_PORT@', "${env.DEPLOYER_HOST}:${env.DEPLOYER_PORT}")
                    xml = xml.replace('@PROJECT_NAME@', names.PROJECT_NAME)
                    xml = xml.replace('@PROJECT_DESC@', names.PROJECT_DESC)
                    xml = xml.replace('@DEPLOYMENT_SET_NAME@', names.DEPLOYMENT_SET_NAME)
                    xml = xml.replace('@DEPLOYMENT_MAP_NAME@', names.DEPLOYMENT_MAP_NAME)
                    xml = xml.replace('@CANDIDATE_NAME@', names.CANDIDATE_NAME)
                    xml = xml.replace('@REPO_ALIAS@', env.REPO_ALIAS)
                    xml = xml.replace('@REPO_DIRECTORY@', env.BUILD_OUTPUT_DIR)
                    xml = xml.replace('@IS_ALIASES@', buildISAliases(targets))
                    xml = xml.replace('@MAP_TARGET_ALIASES@', buildMapTargetAliases(targets))
                    xml = xml.replace('@DEPLOYMENT_ENTRIES@', buildRepositoryEntries(CHANGED_PACKAGES, env.REPO_ALIAS))

                    writeFile(file: env.GENERATED_XML, text: xml, encoding: 'UTF-8')

                    echo "Generated XML: ${env.GENERATED_XML}"
                    echo "XML generated successfully. Content hidden to avoid exposing credentials."
                }
            }
        }

        stage('Create Deployer Project') {
            steps {
                script {
                    if (!fileExists(env.GENERATED_XML)) {
                        error("Generated Project Automator XML not found: ${env.GENERATED_XML}")
                    }

                    if (!fileExists(env.PROJECT_AUTOMATOR)) {
                        error("Project Automator script not found: ${env.PROJECT_AUTOMATOR}")
                    }
                }

                withCredentials([
                    usernamePassword(credentialsId: 'IS_Target_Preprod', usernameVariable: 'DEPLOYER_USER', passwordVariable: 'DEPLOYER_PWD'),
                    usernamePassword(credentialsId: 'IS_Target_Preprod', usernameVariable: 'IS_USER', passwordVariable: 'IS_PWD')
                ]) {
                    sh '''
                        sed -i "s|\\${DEPLOYER_USER}|${DEPLOYER_USER}|g" "${GENERATED_XML}"
                        sed -i "s|\\${DEPLOYER_PWD}|${DEPLOYER_PWD}|g" "${GENERATED_XML}"
                        sed -i "s|\\${IS_USER}|${IS_USER}|g" "${GENERATED_XML}"
                        sed -i "s|\\${IS_PWD}|${IS_PWD}|g" "${GENERATED_XML}"

                        chmod +x "${PROJECT_AUTOMATOR}" || true
                        "${PROJECT_AUTOMATOR}" "${GENERATED_XML}"
                    '''
                }
            }
        }

        stage('Create Snapshot') {
            steps {
                script {
                    if (!fileExists(env.DEPLOYER_CMD)) {
                        error("Deployer command not found: ${env.DEPLOYER_CMD}")
                    }
                }

                withCredentials([
                    usernamePassword(credentialsId: 'IS_Target_Preprod', usernameVariable: 'DEPLOYER_USER', passwordVariable: 'DEPLOYER_PWD')
                ]) {
                    sh '''
                        chmod +x "${DEPLOYER_CMD}" || true

                        "${DEPLOYER_CMD}" --checkpoint \
                            -dc "${EPIC_NAME}" \
                            -project "${EPIC_NAME}" \
                            -host "${DEPLOYER_HOST}" \
                            -port "${DEPLOYER_PORT}" \
                            -user "${DEPLOYER_USER}" \
                            -pwd "${DEPLOYER_PWD}"
                    '''
                }
            }
        }

        stage('Deploy Candidate') {
            steps {
                script {
                    catchError(buildResult: 'FAILURE', stageResult: 'FAILURE') {
                        withCredentials([
                            usernamePassword(credentialsId: 'IS_Target_Preprod', usernameVariable: 'DEPLOYER_USER', passwordVariable: 'DEPLOYER_PWD')
                        ]) {
                            sh '''
                                "${DEPLOYER_CMD}" --deploy \
                                    -project "${EPIC_NAME}" \
                                    -dc "${EPIC_NAME}" \
                                    -host "${DEPLOYER_HOST}" \
                                    -port "${DEPLOYER_PORT}" \
                                    -user "${DEPLOYER_USER}" \
                                    -pwd "${DEPLOYER_PWD}" \
                                    -force
                            '''
                        }
                    }

                    if (currentBuild.currentResult == 'FAILURE') {
                        DEPLOY_STATUS = "FAILED"
                        echo "Deployment failed"
                    } else {
                        DEPLOY_STATUS = "SUCCESS"
                        echo "Deployment succeeded"
                    }
                }
            }
        }

        stage('Rollback If Needed') {
            when {
                expression { DEPLOY_STATUS == "FAILED" }
            }
            steps {
                withCredentials([
                    usernamePassword(credentialsId: 'IS_Target_Preprod', usernameVariable: 'DEPLOYER_USER', passwordVariable: 'DEPLOYER_PWD')
                ]) {
                    sh '''
                        "${DEPLOYER_CMD}" --rollback \
                            -project "${EPIC_NAME}" \
                            -dc "${EPIC_NAME}" \
                            -host "${DEPLOYER_HOST}" \
                            -port "${DEPLOYER_PORT}" \
                            -user "${DEPLOYER_USER}" \
                            -pwd "${DEPLOYER_PWD}"
                    '''
                }
            }
        }

        stage('Zip Build Output') {
            steps {
                sh '''
                    cd "${WORKSPACE}"
                    zip -r build_output.zip build_output
                '''
            }
        }

        stage('Archive Artifacts') {
            steps {
                archiveArtifacts artifacts: 'generated/*.xml, generated/*.log, build_output.zip', allowEmptyArchive: true
            }
        }
    }

    post {
        success {
            script {
                sendDeploymentEmail(
                    'Success',
                    '#27ae60',
                    "We are pleased to inform you that the deployment of ${env.APPLICATION_NAME} has been completed successfully as follows:"
                )
            }
        }

        failure {
            script {
                sendDeploymentEmail(
                    'Failed',
                    '#c0392b',
                    "Please be informed that the deployment of ${env.APPLICATION_NAME} has failed as follows:"
                )
            }
        }

        always {
            echo "Pipeline execution finished."
        }
    }
}

