pipeline {
    agent { label 'AS-L1' }

    options {
        disableConcurrentBuilds()
        timestamps()
    }

    environment {
        APPLICATION_NAME = 'WM-App'
        APP_PROCESS      = 'Deploy'
        COMPONENT_NAME   = 'WM-Package'
        VERSION_NAME     = '1.0.0'

        TARGET_ENV       = 'SIT'
        UCD_WEBURL       = 'http://ucdserver:8080'
        UCD_USERNAME     = 'admin'
        UCD_PASSWORD     = 'admin'
        UDCLIENT         = 'C:\\IBM\\udclient\\udclient.cmd'
        DEPLOY_JSON      = "${WORKSPACE}\\deploy-SIT.json"
    }

    stages {
        stage('Set Build Name') {
            steps {
                script {
                    currentBuild.displayName = "${env.COMPONENT_NAME}-${env.VERSION_NAME}-${env.TARGET_ENV}"
                    currentBuild.description = "Application=${env.APPLICATION_NAME}, Process=${env.APP_PROCESS}, Environment=${env.TARGET_ENV}"
                }
            }
        }

        stage('Generate Deploy JSON') {
            steps {
                script {
                    def payload = """{
  "application": "${env.APPLICATION_NAME}",
  "applicationProcess": "${env.APP_PROCESS}",
  "environment": "${env.TARGET_ENV}",
  "versions": [
    {
      "component": "${env.COMPONENT_NAME}",
      "version": "${env.VERSION_NAME}"
    }
  ]
}"""
                    writeFile file: env.DEPLOY_JSON, text: payload
                }
            }
        }

        stage('Deploy to SIT') {
            steps {
                bat """
                "${UDCLIENT}" -weburl "${UCD_WEBURL}" -username "${UCD_USERNAME}" -password "${UCD_PASSWORD}" requestApplicationProcess "${DEPLOY_JSON}"
                """
            }
        }
    }

    post {
        success {
            echo "SUCCESS: Deployed ${env.COMPONENT_NAME} ${env.VERSION_NAME} to ${env.TARGET_ENV}"
        }
        failure {
            echo "FAILED: ${env.TARGET_ENV} deployment failed"
        }
        always {
            archiveArtifacts artifacts: 'deploy-*.json, **/*.log', allowEmptyArchive: true
        }
    }
}