properties([
    parameters([

        string(
            name: 'EPIC_NAME',
            defaultValue: '',
            description: 'Use a Valid Jira Epic Number'
        ),

        [
            $class: 'ChoiceParameter',
            choiceType: 'PT_SINGLE_SELECT',
            name: 'ENVIRONMENT',
            description: 'Select environment',
            script: [
                $class: 'GroovyScript',
                fallbackScript: [
                    classpath: [],
                    sandbox: true,
                    script: 'return ["DEV"]'
                ],
                script: [
                    classpath: [],
                    sandbox: true,
                    script: '''
                        return ["DEV", "QC", "PROD"]
                    '''
                ]
            ]
        ],

        [
            $class: 'CascadeChoiceParameter',
            choiceType: 'PT_CHECKBOX',
            name: 'TARGET_SCOPE',
            description: 'Select target servers',
            referencedParameters: 'ENVIRONMENT',
            filterable: true,
            filterLength: 2,
            script: [
                $class: 'GroovyScript',
                fallbackScript: [
                    classpath: [],
                    sandbox: true,
                    script: 'return ["QC_APP01"]'
                ],
                script: [
                    classpath: [],
                    sandbox: true,
                    script: '''
                        if (ENVIRONMENT == 'DEV') {
                            return ['QC_APP01', 'QC_APP04']
                        } else if (ENVIRONMENT == 'QC') {
                            return ['QC_APP02', 'QC_APP05']
                        } else if (ENVIRONMENT == 'PROD') {
                            return ['QC_APP03', 'QC_APP06']
                        } else {
                            return ['None']
                        }
                    '''
                ]
            ]
        ],

        [
            $class: 'ChoiceParameter',
            choiceType: 'PT_CHECKBOX',
            name: 'PACKAGES_TO_BUILD',
            description: 'Select Packages',
            filterable: true,
            filterLength: 2,
            script: [
                $class: 'GroovyScript',
                fallbackScript: [
                    classpath: [],
                    sandbox: true,
                    script: 'return ["TawnMotorNonRetail"]'
                ],
                script: [
                    classpath: [],
                    sandbox: true,
                    script: '''
                        return [
                            "TawnMotorNonRetail",
                            "TawnSMESalesCRM"
                        ]
                    '''
                ]
            ]
        ]
    ])
])

pipeline {
    agent { label 'SAG_NODE' }

    tools {
        jdk 'JDK_HOME'
        ant 'ANT_HOME'
    }

    options {
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '4'))
        timestamps()
    }

    environment {
        SAG_HOME              = '/sag/dbp1011'

        ABE_BUILD_FILE        = "${SAG_HOME}/common/AssetBuildEnvironment/master_build/build.xml"
        DEPLOYER_BIN          = "${SAG_HOME}/IntegrationServer/instances/default/packages/WmDeployer/bin"
        PROJECT_AUTOMATOR     = "${DEPLOYER_BIN}/projectautomatorUnix.sh"
        DEPLOYER_CMD          = "${DEPLOYER_BIN}/Deployer.sh"

        TEMP_SRC              = "${WORKSPACE}/.tmp_build_src"
        BUILD_OUTPUT_DIR      = "${WORKSPACE}/build_output"
        GENERATED_DIR         = "${WORKSPACE}/generated"
        GENERATED_XML         = "${WORKSPACE}/generated/Deployment_ProjectAutomator.xml"
        BUILD_LOG_FILE        = "${WORKSPACE}/generated/abe-build.log"

        TEMPLATE_XML          = 'deployer/templates/ProjectAutomator.Repository.template.xml'

        DEPLOYER_HOST         = 'localhost'
        DEPLOYER_PORT         = '5555'
        REPO_ALIAS            = 'BuildRepo'
    }

    stages {

        stage('Validate Input') {
            steps {
                script {
                    if (!params.EPIC_NAME?.trim()) {
                        error("EPIC_NAME is required")
                    }

                    if (!params.ENVIRONMENT?.trim()) {
                        error("ENVIRONMENT is required")
                    }

                    def selectedTargets  = getSelected(params.TARGET_SCOPE)
                    def selectedPackages = getSelected(params.PACKAGES_TO_BUILD)

                    if (selectedTargets.isEmpty()) {
                        error("Select at least one target server")
                    }

                    if (selectedPackages.isEmpty()) {
                        error("Select at least one package")
                    }

                    if (!fileExists(env.ABE_BUILD_FILE)) {
                        error("ABE build.xml not found: ${env.ABE_BUILD_FILE}")
                    }
                }

                sh """
                    set -e
                    test -x "${env.PROJECT_AUTOMATOR}" || { echo "projectautomatorUnix.sh not found or not executable: ${env.PROJECT_AUTOMATOR}"; exit 1; }
                    test -x "${env.DEPLOYER_CMD}" || { echo "Deployer.sh not found or not executable: ${env.DEPLOYER_CMD}"; exit 1; }
                """

                script {
                    echo "NODE_NAME         : ${env.NODE_NAME}"
                    echo "WORKSPACE         : ${env.WORKSPACE}"
                    echo "SAG_HOME          : ${env.SAG_HOME}"
                    echo "ABE_BUILD_FILE    : ${env.ABE_BUILD_FILE}"
                    echo "PROJECT_AUTOMATOR : ${env.PROJECT_AUTOMATOR}"
                    echo "DEPLOYER_CMD      : ${env.DEPLOYER_CMD}"
                    echo "ENVIRONMENT       : ${params.ENVIRONMENT}"
                    echo "EPIC_NAME         : ${params.EPIC_NAME}"
                    echo "TARGET_SCOPE      : ${getSelected(params.TARGET_SCOPE).join(', ')}"
                    echo "PACKAGES_TO_BUILD : ${getSelected(params.PACKAGES_TO_BUILD).join(', ')}"
                }
            }
        }

        stage('Set Build Name') {
            steps {
                script {
                    currentBuild.displayName = "${params.EPIC_NAME}"
                    currentBuild.description = "EPIC=${params.EPIC_NAME} | ENV=${params.ENVIRONMENT}"
                }
            }
        }

        stage('Checkout Repo') {
            steps {
                script {
                    def branchName = getEnvironmentConfig(params.ENVIRONMENT).branch

                    deleteDir()

                    bbs_checkout(
                        branches: [[name: "*/${branchName}"]],
                        credentialsId: 'Admin_Bitbucket',
                        id: '75b95ed8-28cb-489d-b2fd-a56ac6b6f2ae',
                        projectName: 'JIRA',
                        repositoryName: 'sag',
                        serverId: '2492752c-5622-4c29-9972-c1c0f572b1f6'
                    )
                }
            }
        }

        stage('Validate Repo Content') {
            steps {
                script {
                    def packages = getSelected(params.PACKAGES_TO_BUILD)

                    if (!fileExists(env.TEMPLATE_XML)) {
                        error("Template XML not found after checkout: ${env.TEMPLATE_XML}")
                    }

                    for (pkg in packages) {
                        if (!fileExists("Packages/${pkg}")) {
                            error("Package not found in repo: Packages/${pkg}")
                        }
                    }
                }
            }
        }

        stage('Prepare Build Source') {
            steps {
                sh """
                    set -e
                    rm -rf "${env.TEMP_SRC}" "${env.BUILD_OUTPUT_DIR}" "${env.GENERATED_DIR}"
                    mkdir -p "${env.TEMP_SRC}/packages"
                    mkdir -p "${env.BUILD_OUTPUT_DIR}"
                    mkdir -p "${env.GENERATED_DIR}"
                """

                script {
                    def packages = getSelected(params.PACKAGES_TO_BUILD)

                    for (pkg in packages) {
                        sh """
                            set -e
                            test -d "${WORKSPACE}/Packages/${pkg}" || { echo "Missing package: ${pkg}"; exit 1; }
                            mkdir -p "${env.TEMP_SRC}/packages/${pkg}"
                            cp -R "${WORKSPACE}/Packages/${pkg}/." "${env.TEMP_SRC}/packages/${pkg}/"
                        """
                    }
                }
            }
        }

        stage('ABE Build') {
            steps {
                sh """
                    set -e

                    ant -f "${env.ABE_BUILD_FILE}" build \\
                      -Dsag.install.dir="${env.SAG_HOME}" \\
                      -Dbuild.output.dir="${env.BUILD_OUTPUT_DIR}" \\
                      -Dbuild.source.dir="${env.TEMP_SRC}" \\
                      -Denable.checkout=false \\
                      -Denable.archive=false \\
                      -Denable.build.IS=true \\
                      -Denable.build.MWS=false \\
                      -Denable.build.BPM=false \\
                      -Denable.build.TN=false \\
                      -Denable.build.Optimize=false \\
                      -Denable.build.Broker=false \\
                      -Denable.build.EDA=false \\
                      -Denable.build.RULES=false \\
                      -Denable.build.UniversalMessaging=false \\
                      -Dbuild.log.enable=true \\
                      -Dbuild.log.fileName="${env.BUILD_LOG_FILE}" \\
                      -Dbuild.logLevel=INFO \\
                      -Dbuild.exit.error=true
                """
            }
        }

        stage('Generate Project Automator XML') {
            steps {
                script {
                    def targets  = getTargetConfigs(params.ENVIRONMENT, params.TARGET_SCOPE)
                    def packages = getSelected(params.PACKAGES_TO_BUILD)
                    def names    = buildNames(params.EPIC_NAME, params.ENVIRONMENT)

                    def xml = readFile(file: env.TEMPLATE_XML, encoding: 'UTF-8')

                    xml = xml.replace('@DEPLOYER_HOST_PORT@', "${env.DEPLOYER_HOST}:${env.DEPLOYER_PORT}")
                    xml = xml.replace('@PROJECT_NAME@', names.PROJECT_NAME)
                    xml = xml.replace('@PROJECT_DESC@', names.PROJECT_DESC)
                    xml = xml.replace('@DEPLOYMENT_SET_NAME@', names.DEPLOYMENT_SET_NAME)
                    xml = xml.replace('@DEPLOYMENT_MAP_NAME@', names.DEPLOYMENT_MAP_NAME)
                    xml = xml.replace('@CANDIDATE_NAME@', names.CANDIDATE_NAME)
                    xml = xml.replace('@REPO_ALIAS@', env.REPO_ALIAS)
                    xml = xml.replace('@REPO_DIRECTORY@', env.BUILD_OUTPUT_DIR)
                    xml = xml.replace('@IS_ALIASES@', buildISAliases(targets))
                    xml = xml.replace('@MAP_TARGET_ALIASES@', buildMapTargetAliases(targets))
                    xml = xml.replace('@DEPLOYMENT_ENTRIES@', buildRepositoryEntries(packages, env.REPO_ALIAS))

                    writeFile(file: env.GENERATED_XML, text: xml, encoding: 'UTF-8')

                    echo "Generated XML: ${env.GENERATED_XML}"
                    echo "===== GENERATED XML START ====="
                    echo readFile(file: env.GENERATED_XML, encoding: 'UTF-8')
                    echo "===== GENERATED XML END ====="
                }
            }
        }

        stage('Create Deployer Project') {
            steps {
                withCredentials([
                    string(
                        credentialsId: 'deployer-creds',
                        variable: 'DEP_PWD'
                    ),
                    string(
                        credentialsId: 'IS-creds',
                        variable: 'IS_PWD'
                    )
                ]) {
                    sh """
                        set -e
                        export DEP_PWD="${DEP_PWD}"
                        export IS_PWD="${IS_PWD}"

                        "${env.PROJECT_AUTOMATOR}" "${env.GENERATED_XML}"
                    """
                }
            }
        }

        stage('Deploy Candidate') {
            steps {
                script {
                    def names = buildNames(params.EPIC_NAME, params.ENVIRONMENT)

                    withCredentials([
                        string(
                            credentialsId: 'deployer-creds',
                            variable: 'DEP_PWD'
                        )
                    ]) {
                        sh """
                            set -e
                            export DEP_PWD="${DEP_PWD}"

                            "${env.DEPLOYER_CMD}" \\
                              --deploy \\
                              -project "${names.PROJECT_NAME}" \\
                              -dc "${names.CANDIDATE_NAME}" \\
                              -host "${env.DEPLOYER_HOST}" \\
                              -port "${env.DEPLOYER_PORT}" \\
                              -user "Administrator" \\
                              -pwd "${DEP_PWD}" \\
                              -force
                        """
                    }
                }
            }
        }

        stage('Archive Artifacts') {
            steps {
                writeFile file: 'epic.txt', text: params.EPIC_NAME.trim()
                archiveArtifacts artifacts: 'epic.txt, generated/*.xml, generated/*.log', allowEmptyArchive: true
            }
        }
    }

    post {
        success {
            echo "Deployment completed successfully."
        }
        failure {
            echo "Deployment failed. Check ABE build output, generated XML, and Deployer logs."
        }
        always {
            echo "Pipeline execution finished."
        }
    }
}

def getSelected(val) {
    if (!val?.trim()) {
        return []
    }

    return val.split(',')
              .collect { it.trim() }
              .findAll { it && it != 'None' }
}

def buildNames(epic, environment) {
    def epicname = epic.trim()

    return [
        PROJECT_NAME        : epicname,
        PROJECT_DESC        : "${epicname} - ${environment}",
        DEPLOYMENT_SET_NAME : "${epicname}_DEPLOYMENT_SET",
        DEPLOYMENT_MAP_NAME : "${epicname}_DEPLOYMENT_MAP",
        CANDIDATE_NAME      : epicname
    ]
}

def buildRepositoryEntries(pkgs, repoAlias) {
    return pkgs.collect { pkg ->
        """                <Composite name="${pkg}" srcAlias="${repoAlias}" type="IS"/>"""
    }.join('\n')
}

def buildISAliases(targets) {
    return targets.collect { target ->
        """            <isalias name="${target.alias}">
                <host>${target.host}</host>
                <port>${target.port}</port>
                <user>Administrator</user>
                <pwd>\${IS_PWD}</pwd>
                <useSSL>false</useSSL>
                <installDeployerResource>false</installDeployerResource>
                <Test>false</Test>
            </isalias>"""
    }.join('\n')
}

def buildMapTargetAliases(targets) {
    return targets.collect { target ->
        """                <alias type="IS">${target.alias}</alias>"""
    }.join('\n')
}

def getEnvironmentConfig(envName) {
    def config = [
        DEV : [branch: 'DEV'],
        QC  : [branch: 'QC'],
        PROD: [branch: 'PROD']
    ]

    if (!config.containsKey(envName)) {
        error("Unsupported ENVIRONMENT: ${envName}")
    }

    return config[envName]
}

def getTargetConfigs(envName, scopeCsv) {
    def targetConfigMap = [
        'QC_APP01':[alias:'QC_APP01', host:'10.24.7.181', port:'5555'],
        'QC_APP02':[alias:'QC_APP02', host:'10.24.7.182', port:'5555'],
        'QC_APP03':[alias:'QC_APP03', host:'10.24.7.183', port:'5555'],
        'QC_APP04':[alias:'QC_APP04', host:'10.24.7.184', port:'5555'],
        'QC_APP05':[alias:'QC_APP05', host:'10.24.7.185', port:'5555'],
        'QC_APP06':[alias:'QC_APP06', host:'10.24.7.186', port:'5555']
    ]

    def allowedTargetsByEnvironment = [
        DEV : ['QC_APP01', 'QC_APP04'],
        QC  : ['QC_APP02', 'QC_APP05'],
        PROD: ['QC_APP03', 'QC_APP06']
    ]

    def selectedTargets = getSelected(scopeCsv)

    selectedTargets.each { t ->
        if (!allowedTargetsByEnvironment[envName].contains(t)) {
            error("${t} is not allowed for environment ${envName}")
        }
    }

    return selectedTargets.collect { t -> targetConfigMap[t] }
}