properties([
    parameters([

        string(
            name: 'EPIC_NAME',
            defaultValue: '',
            description: 'Use a Valid Jira Epic Number'
        ),

        [
            $class: 'ChoiceParameter',
            choiceType: 'PT_SINGLE_SELECT',
            name: 'ENVIRONMENT',
            description: 'Select environment',
            script: [
                $class: 'GroovyScript',
                fallbackScript: [
                    classpath: [],
                    sandbox: true,
                    script: 'return ["DEV"]'
                ],
                script: [
                    classpath: [],
                    sandbox: true,
                    script: '''
                        return ["DEV", "QC", "PROD"]
                    '''
                ]
            ]
        ],

        [
            $class: 'CascadeChoiceParameter',
            choiceType: 'PT_CHECKBOX',
            name: 'TARGET_SCOPE',
            description: 'Select target servers',
            referencedParameters: 'ENVIRONMENT',
            filterable: true,
            filterLength: 2,
            script: [
                $class: 'GroovyScript',
                fallbackScript: [
                    classpath: [],
                    sandbox: true,
                    script: 'return ["QC_APP01"]'
                ],
                script: [
                    classpath: [],
                    sandbox: true,
                    script: '''
                        if (ENVIRONMENT == 'DEV') {
                            return ['QC_APP01', 'QC_APP04']
                        } else if (ENVIRONMENT == 'QC') {
                            return ['QC_APP02', 'QC_APP05']
                        } else if (ENVIRONMENT == 'PROD') {
                            return ['QC_APP03', 'QC_APP06']
                        } else {
                            return ['None']
                        }
                    '''
                ]
            ]
        ],

        [
            $class: 'ChoiceParameter',
            choiceType: 'PT_CHECKBOX',
            name: 'PACKAGES_TO_BUILD',
            description: 'Select packages',
            filterable: true,
            filterLength: 2,
            script: [
                $class: 'GroovyScript',
                fallbackScript: [
                    classpath: [],
                    sandbox: true,
                    script: 'return ["TawnMotorNonRetail"]'
                ],
                script: [
                    classpath: [],
                    sandbox: true,
                    script: '''
                        return [
                            "TawnMotorNonRetail",
                            "TawnSMESalesCRM"
                        ]
                    '''
                ]
            ]
        ]
    ])
])

