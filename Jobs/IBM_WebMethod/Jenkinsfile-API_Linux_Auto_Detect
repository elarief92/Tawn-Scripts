"""
                    }
                }
            }
        }
*/

        stage('Test Updated Packages') {
            steps {
                script {
                    writeFile file: 'epic.txt', text: params.EPIC_NAME.trim()

                    for (pkg in CHANGED_PACKAGES) {
                        echo "TEST: updated package detected -> ${pkg}"
                    }
                }
            }
        }

        stage('Archive Artifacts') {
            steps {
                archiveArtifacts artifacts: 'epic.txt, generated/*.xml, generated/*.log, build_output/**', allowEmptyArchive: true
            }
        }
    }

    post {
        success {
            script {
                sendDeploymentEmail(
                    'Success',
                    '#27ae60',
                    "We are pleased to inform you that the deployment of ${env.APPLICATION_NAME} has been completed successfully as follows:"
                )
            }
        }

        failure {
            script {
                sendDeploymentEmail(
                    'Failed',
                    '#c0392b',
