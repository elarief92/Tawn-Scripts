@Library('Tawuniya-lib@main') _

pipeline {
  agent none

  parameters {
    string(name: 'EPIC', defaultValue: '', description: 'Use a Valid Jira Epic Number')
  }

  environment {
    BRANCH_NAME = 'UAT'
  }

  stages {
    stage('Build + Scan') {
      steps {
        script {
          def branchName = env.BRANCH_NAME.toString()
          def envLower   = branchName.toLowerCase()
          def appName    = 'one-payment'

          bffBuildScan([
            epic: params.EPIC,
            branch: branchName,
            lob: 'DXP',
            appName: appName,
            buildAgent: 'built-in',
            sonarAgent: 'SonarQube',

            bbs: [
              credentialsId: 'Admin_Bitbucket',
              id: '75b95ed8-28cb-489d-b2fd-a56ac6b6f2ae',
              projectName: 'DXP',
              repositoryName: 'BFF-WEB-PAYMENT',
              serverId: '2492752c-5622-4c29-9972-c1c0f572b1f6'
            ],

            preBuildCmd: """
                robocopy "E:\\Jenkins\\Home\\workspace\\Digital Experience Platforms\\Configuration\\${branchName}\\bff-web-payment" "E:\\Jenkins\\Home\\workspace\\sonarqube\\tawn\\BFF-WEB-PAYMENT" /E /J /COPY:DATS /MT:1 /IS /IT /IM /X /V /NP /NODCOPY /XD .*
                if %ERRORLEVEL% LEQ 7 exit /b 0
                exit /b %ERRORLEVEL%
                """,

            mvnCmd: "mvn clean package -Denvironment=${envLower} -DapplicationName=${appName} -DlogDirectory=\"/u01/Logs\" -Dbuild.finalName=${appName} ",

            sonar: [
              server: 'SonarQube',
              projectKey: 'BFF-WEB-PAYMENT',
              sources: 'src/main/java',
              binaries: 'target/classes'
            ]
          ])
        }
      }
    }
  }
}