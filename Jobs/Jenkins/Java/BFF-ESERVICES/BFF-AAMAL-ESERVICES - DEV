@Library('Tawuniya-lib@main') _

pipeline {
  agent none

  parameters {
    string(name: 'EPIC', defaultValue: '', description: 'Use a Valid Jira Epic Number')

    string(
      name: 'PR_ID',
      defaultValue: '',
      description: 'Optional, Bitbucket Pull Request ID. Filled automatically by Generic Webhook Trigger'
    )

    string(
      name: 'PR_SOURCE_BRANCH',
      defaultValue: '',
      description: 'Optional, Feature/source branch. Filled automatically by Generic Webhook Trigger'
    )
  }

  environment {
    BRANCH_NAME = 'DEV'
  }

  stages {
    stage('Build + Scan') {
      steps {
        script {
          def branchName = env.BRANCH_NAME.toString()
          def envLower   = branchName.toLowerCase()
          def appName    = 'aamal-api'

          bffBuildScan([
            epic: params.EPIC,
            branch: branchName,
            lob: 'DXP',
            appName: appName,
            buildAgent: 'built-in',
            sonarAgent: 'SonarQube',

            bbs: [
              credentialsId: 'Admin_Bitbucket',
              id: '75b95ed8-28cb-489d-b2fd-a56ac6b6f2ae',
              projectName: 'DXP',
              repositoryName: 'BFF-ESERVICES',
              serverId: '2492752c-5622-4c29-9972-c1c0f572b1f6',
              remoteName: 'bff-eservices'
            ],

            mvnCmd: "mvn -Dmaven.compiler.fork=true -Dmaven.compiler.executable=\"C:\\Program Files\\Java\\jdk-1.8\\bin\\javac.exe\" clean package -Denvironment=${envLower} -DapplicationName=${appName} -DlogDirectory=\"/u01/Logs\"",

            sonar: [
              server: 'SonarQube',
              hostUrl: 'https://sonarqube.tawuniya.com',
              apiTokenCredentialsId: 'jenkins-sonar-api',

              mainGate: 'Quality Gate-Tawuniya',
              prGate: 'Refactor Gate',

              projectKey: 'BFF-AAMAL-ESERVICES',

              prKey: params.PR_ID,
              prBranch: params.PR_SOURCE_BRANCH,

              sources: 'src/main/java',
              tests: '',

              binaries: 'target/classes',
              junitReports: 'target/surefire-reports/*.xml',
              coverageReport: 'target/site/jacoco/jacoco.xml',

              coverageExclusions: '',
              exclusions: '',
              cpdExclusions: ''
            ],

            artifacts: [
              path: 'target/*.war,epic.txt,artifact_version.txt'
            ]
          ])
        }
      }
    }
  }
}