@Library('Tawuniya-lib@main') _

pipeline {
  agent none

  parameters {
    string(
      name: 'EPIC',
      defaultValue: '',
      description: 'Use a Valid Jira Epic Number'
    )
  }

  environment {
    BRANCH_NAME = 'QC'
    NODE_TLS_REJECT_UNAUTHORIZED = '0'
    GIT_SSL_NO_VERIFY = 'true'
  }

  stages {
    stage('Build + Scan') {
      steps {
        script {
          reactBuildScan(
            epic: params.EPIC,
            branch: env.BRANCH_NAME,
            lob: 'DXP',
            buildAgent: 'built-in',
            secretScanningAgent: 'built-in',
            sonarAgent: 'SonarQube',

            bbs: [
              credentialsId: 'Admin_Bitbucket',
              id: '75b95ed8-28cb-489d-b2fd-a56ac6b6f2ae',
              projectName: 'DXP',
              repositoryName: 'DH-General-V3',
              remoteName: 'dh-general-v3',
              serverId: '2492752c-5622-4c29-9972-c1c0f572b1f6'
            ],

            app: [
              path: 'apps/home-insurance/',
              packageFile: 'package.json'
            ],

            node: [
              resetCmd: 'npx nx reset',
              installCmd: 'npm install --legacy-peer-deps',
              buildCmd: 'npx nx build home-insurance --configuration=qa',
              testCoverageCmd: 'npx vitest run --coverage --passWithNoTests --config apps/home-insurance/vitest.config.mts --dir apps/home-insurance --reporter=default --reporter=junit --outputFile.junit=reports/junit.xml'
            ],

            artifacts: [
              path: 'dist/apps/home-insurance/**'
            ],

            sonar: [
              projectKey: 'FE-HOME-INSURANCE-V3',

              mainGate: 'Quality Gate-Tawuniya',
              prGate: 'Refactor Gate',

              sources: 'apps/home-insurance/src',
              tests: 'apps/home-insurance/src',

              inclusions: 'apps/home-insurance/src/**/*.ts,apps/home-insurance/src/**/*.tsx',
              testInclusions: '**/*.test.ts,**/*.test.tsx,**/*.spec.ts,**/*.spec.tsx',

              tsconfigPaths: 'apps/home-insurance/tsconfig.json',
              lcovReportPath: 'coverage/lcov.info',

              exclusions: '**/*.map,**/node_modules/**,**/dist/**,**/coverage/**,**/reports/**,**/*.ttf,**/*.otf,**/*.woff,**/*.woff2,**/*.gif,**/*.svg',
              coverageExclusions: '**/*.test.ts,**/*.test.tsx,**/*.spec.ts,**/*.spec.tsx,**/tests/**,**/*.d.ts,**/assets/**',
              cpdExclusions: ''
            ]
          )
        }
      }
    }
  }
}