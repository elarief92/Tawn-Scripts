@Library('Tawuniya-lib@main') _

pipeline {

    agent { label 'built-in' }

    environment {
        NEXUS_URL        = 'http://nexus.tawuniya.com/repository/rollback-packages'
        CREDENTIAL_ID    = 'nexus-upload'
        SOURCE_JOB_NAME  = 'DH-MBI-CLAIMS-NR'
        SOURCE_JOB_PATH  = 'Sonarqube/tawn/DH-MBI-CLAIMS-NR'
        BUILD_FOLDER     = 'dist/apps/mbi-claims-nr'
        EMAIL_RECIPIENTS = 'melarief@tawuniya.com'
    }

    stages {

        stage('Upload to Nexus') {
            steps {
                script {
                    ReactNexusUpload(
                        nexusUrl: env.NEXUS_URL,
                        credentialId: env.CREDENTIAL_ID,
                        sourceJobName: env.SOURCE_JOB_NAME,
                        sourceJobPath: env.SOURCE_JOB_PATH,
                        buildFolder: env.BUILD_FOLDER
                    )
                }
            }
        }
    }
}