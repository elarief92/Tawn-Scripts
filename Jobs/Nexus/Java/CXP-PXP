@Library('Tawuniya-lib@main') _

pipeline {
    agent { label 'built-in' }

    environment {
        NEXUS_URL        = 'http://nexus.tawuniya.com/repository/rollback-packages'
        CREDENTIAL_ID    = 'nexus-upload'
        DIR              = 'E:/Jenkins/Home/workspace/Sonarqube/tawn/CXP-PXP/target/'
        EMAIL_RECIPIENTS = 'melarief@tawuniya.com'
